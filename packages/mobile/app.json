{
  "expo": {
    "name": "Uzavita",
    "slug": "uzavita",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "scheme": "uzavita",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D9488"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.uzavita.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Uzavita needs camera access for biometric enrollment and document scanning.",
        "NSFaceIDUsageDescription": "Uzavita uses Face ID for secure, passwordless login.",
        "NSBluetoothAlwaysUsageDescription": "Uzavita connects to medical wearables and health monitoring devices via Bluetooth.",
        "NSBluetoothPeripheralUsageDescription": "Uzavita communicates with Bluetooth-enabled medical devices to sync your health data.",
        "NSHealthShareUsageDescription": "Uzavita reads your health data to provide personalized health insights and triage recommendations.",
        "NSHealthUpdateUsageDescription": "Uzavita writes health data from connected medical devices to your Health app.",
        "NSMicrophoneUsageDescription": "Uzavita uses the microphone for voice-based symptom description during triage.",
        "NSLocationWhenInUseUsageDescription": "Uzavita uses your location to find nearby healthcare facilities and for regional health insights."
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.background-delivery": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#0D9488"
      },
      "package": "com.uzavita.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECORD_AUDIO",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "SCHEDULE_EXACT_ALARM",
        "POST_NOTIFICATIONS",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "blockedPermissions": [
        "READ_PHONE_STATE"
      ]
    },
    "plugins": [
      "expo-camera",
      "expo-local-authentication",
      "expo-secure-store",
      "expo-notifications",
      "expo-sqlite",
      [
        "expo-font",
        {
          "fonts": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "uzavita-mobile"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/uzavita-mobile",
      "fallbackToCacheTimeout": 30000
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "notification": {
      "icon": "./src/assets/notification-icon.png",
      "color": "#0D9488",
      "androidMode": "default",
      "androidCollapsedTitle": "Uzavita"
    }
  }
}
