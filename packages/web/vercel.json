{
  "buildCommand": "echo 'pre-built'",
  "installCommand": "echo 'pre-installed'",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/graphql", "destination": "https://uzavita-api-production.up.railway.app/graphql" },
    { "source": "/api/(.*)", "destination": "https://uzavita-api-production.up.railway.app/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
