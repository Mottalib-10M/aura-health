# =============================================================================
# Aura Health ML Service -- Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in the values.
# NEVER commit the `.env` file to version control.

# -- Infrastructure -----------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://aura:aura@localhost:5432/aura
REDIS_URL=redis://localhost:6379/0
KAFKA_BROKERS=localhost:9092

# -- LLM / AI Providers ------------------------------------------------------
LITELLM_PROXY_URL=http://localhost:4000
LITELLM_API_KEY=sk-litellm-xxx
DEEPSEEK_API_KEY=sk-deepseek-xxx
OPENAI_API_KEY=sk-openai-xxx
ANTHROPIC_API_KEY=sk-ant-xxx

# -- Model Serving ------------------------------------------------------------
MODEL_CACHE_DIR=/tmp/aura-models
VLLM_HOST=http://localhost:8000

# -- Application --------------------------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=development
SERVICE_NAME=aura-ml-service
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# -- Triage Tuning ------------------------------------------------------------
TRIAGE_CONFIDENCE_THRESHOLD=0.65
TRIAGE_MAX_RETRIES=2

# -- Forecasting --------------------------------------------------------------
FORECAST_HORIZON_MONTHS=6
