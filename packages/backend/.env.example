# ─────────────────────────────────────────────
# Uzavita Backend — Environment Variables
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000

# PostgreSQL (TimescaleDB)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=uzavita
DB_USER=uzavita
DB_PASSWORD=change_me_in_production

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka
KAFKA_BROKERS=localhost:9092

# JWT
JWT_SECRET=replace-with-a-strong-256-bit-secret
JWT_EXPIRES_IN=8h

# AI / LiteLLM Proxy
LITELLM_URL=http://localhost:4001
LITELLM_API_KEY=sk-litellm-master-key
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SMTP (Email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@uzavita.com

# Blockchain (Hyperledger Fabric)
HLF_PEER_ENDPOINT=grpcs://localhost:7051
HLF_MSP_ID=Org1MSP
HLF_CHANNEL=uzavitachannel
HLF_CHAINCODE=audit
HLF_CERT_PATH=
HLF_KEY_PATH=

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
